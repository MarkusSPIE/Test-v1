<Window x:Class="SpieRibbon.Algemeen.ExportSchedule.ScheduleExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPIE Toolbox - Export Schedule"
        Height="440" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <DockPanel>

        <Border DockPanel.Dock="Top" Background="#003772" Padding="14,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="14" Height="14" Fill="#E31C18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="Export schedule" Foreground="White" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="Gray" FontSize="12"
                       Text="Select the schedule(s) to export. Hold Ctrl or Shift to select more than one."/>

            <ListBox x:Name="ScheduleListBox" Grid.Row="1" SelectionMode="Extended"
                     DisplayMemberPath="Name"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="ExportButton" Content="Export..." Width="90" Margin="0,0,8,0" Click="ExportButton_Click" IsDefault="True"/>
                <Button x:Name="CancelButton" Content="Cancel" Width="90" IsCancel="True"/>
            </StackPanel>
        </Grid>

    </DockPanel>
</Window>
