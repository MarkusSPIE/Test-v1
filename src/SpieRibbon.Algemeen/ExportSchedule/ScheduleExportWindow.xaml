<Window x:Class="SpieRibbon.Algemeen.ExportSchedule.ScheduleExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPIE Ribbon - Export Schedule"
        Height="420" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap"
                   Text="Select the schedule(s) to export. Hold Ctrl or Shift to select more than one."/>

        <ListBox x:Name="ScheduleListBox" Grid.Row="1" SelectionMode="Extended"
                 DisplayMemberPath="Name"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ExportButton" Content="Export..." Width="90" Margin="0,0,8,0" Click="ExportButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
