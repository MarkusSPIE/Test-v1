<Window x:Class="SpieRibbon.UI.PatchNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPIE Ribbon - Patch Notes"
        Height="420" Width="360"
        MinHeight="240" MinWidth="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <DockPanel>

        <Border x:Name="TitleBarHost" DockPanel.Dock="Top"/>

        <ScrollViewer Margin="14" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="NotesText" TextWrapping="Wrap" FontSize="12" FontFamily="Consolas"/>
        </ScrollViewer>

    </DockPanel>
</Window>
