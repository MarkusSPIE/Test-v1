<Window x:Class="SpieRibbon.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPIE Toolbox - Settings"
        Height="360" Width="300"
        MinHeight="220" MinWidth="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <DockPanel>

        <Border DockPanel.Dock="Top" Background="#003772" Padding="14,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="14" Height="14" Fill="#E31C18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="Settings" Foreground="White" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <DockPanel Margin="14,12,14,14">
            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="Gray" FontSize="12"
                       Text="Enable the modules you want to see in the toolbox. Changes apply immediately."/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="OkButton" Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OkButton_Click"/>
                <Button x:Name="CancelButton" Content="Cancel" Width="80" IsCancel="True"/>
            </StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ModuleCheckList"/>
            </ScrollViewer>
        </DockPanel>

    </DockPanel>
</Window>
