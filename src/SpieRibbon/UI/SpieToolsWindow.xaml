<Window x:Class="SpieRibbon.UI.SpieToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPIE Toolbox"
        Height="480" Width="400"
        MinHeight="260" MinWidth="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True">
    <DockPanel>

        <Border DockPanel.Dock="Top" Background="#003772" Padding="14,10">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Fill="#E31C18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SPIE toolbox" Foreground="White" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="SettingsButton" DockPanel.Dock="Right" Click="SettingsButton_Click"
                        Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand"
                        ToolTip="Settings">
                    <TextBlock x:Name="SettingsGlyph" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"/>
                </Button>
            </DockPanel>
        </Border>

        <TextBlock x:Name="FooterText" DockPanel.Dock="Bottom"
                    FontSize="10" Foreground="Gray"
                    HorizontalAlignment="Center" Margin="0,8,0,8"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="108"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F4F6F8" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
                <StackPanel x:Name="SidebarPanel"/>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ContentPanel" Margin="12,10,10,10"/>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>
