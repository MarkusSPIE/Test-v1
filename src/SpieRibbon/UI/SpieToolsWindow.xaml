<Window x:Class="SpieRibbon.UI.SpieToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPIE Ribbon"
        Height="480" Width="400"
        MinHeight="260" MinWidth="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="True">
    <DockPanel>

        <Border x:Name="TitleBarHost" DockPanel.Dock="Top"/>

        <TextBlock x:Name="FooterText" DockPanel.Dock="Bottom"
                    FontSize="10" Foreground="Gray"
                    HorizontalAlignment="Center" Margin="0,8,0,8"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="108"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F4F6F8" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
                <StackPanel x:Name="SidebarPanel"/>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ContentPanel" Margin="12,10,10,10"/>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>
