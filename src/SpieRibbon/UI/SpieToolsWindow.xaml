<Window x:Class="SpieRibbon.UI.SpieToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPIE Toolbox"
        Height="480" Width="260"
        MinHeight="220" MinWidth="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True">
    <DockPanel Margin="10">
        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,8">
            <TextBlock Text="SPIE Toolbox" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            <Button x:Name="SettingsButton" DockPanel.Dock="Right" Content="Settings"
                    Padding="8,3" Click="SettingsButton_Click"/>
        </DockPanel>
        <TextBlock x:Name="FooterText" DockPanel.Dock="Bottom"
                    FontSize="10" Foreground="Gray"
                    HorizontalAlignment="Center" Margin="0,10,0,0"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ModulesPanel"/>
        </ScrollViewer>
    </DockPanel>
</Window>
