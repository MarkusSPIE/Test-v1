<Window x:Class="SpieRibbon.BimManagement.IfcExport.IfcExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPIE Ribbon - IFC Export (2GW)"
        Height="480" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="IFC settings" Margin="0,0,0,10">
            <StackPanel Margin="6">
                <DockPanel Margin="0,4">
                    <TextBlock Text="IFC version" Width="120" VerticalAlignment="Center"/>
                    <ComboBox x:Name="IfcVersionCombo" DisplayMemberPath="Label"/>
                </DockPanel>
                <CheckBox x:Name="ExportBaseQuantitiesCheck" Content="Export base quantities" Margin="0,6,0,0"/>
            </StackPanel>
        </GroupBox>

        <TextBlock Grid.Row="1" Margin="0,0,0,6" TextWrapping="Wrap"
                   Text="Select the view(s) to export. Building Name will be set to match each view's name before it is exported. Hold Ctrl or Shift to select more than one."/>

        <ListBox x:Name="ViewListBox" Grid.Row="2" SelectionMode="Extended"
                 DisplayMemberPath="Name"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ExportButton" Content="Export..." Width="90" Margin="0,0,8,0" Click="ExportButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
